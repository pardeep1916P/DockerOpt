# Example .env file for DockerOpt
# Copy this file to .env and fill in the actual values

# OpenAI-compatible API Key (works with KodeKloud, OpenAI, or any compatible provider)
VITE_OPENAI_API_KEY=your-api-key-here

# Base URL for the API (default: OpenAI)
VITE_OPENAI_BASE_URL=https://api.openai.com/v1

# Default model for single-model mode
VITE_OPENAI_MODEL=gpt-5.2

# Multi-model expert system configuration (optional)
# Format: router=model;security=model;size=model;performance=model;best_practices=model
# Example with diverse models:
# VITE_OPENAI_MODELS=router=anthropic/claude-sonnet-4.5;security=x-ai/grok-4;size=gpt-5.2;performance=google/gemini-3-pro-preview;best_practices=deepseek/deepseek-v3.2
#
# Alternative comma-separated format (order: router, security, size, performance, best_practices):
# VITE_OPENAI_MODELS=anthropic/claude-sonnet-4.5,x-ai/grok-4,gpt-5.2,google/gemini-3-pro-preview,deepseek/deepseek-v3.2
